generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Ruolo {
  DIPENDENTE
  RESPONSABILE_AMMINISTRATIVO
}

enum StatoRichiesta {
  IN_ATTESA
  APPROVATA
  RIFIUTATA
  LIQUIDATA
}

model Utente {
  id        Int      @id @default(autoincrement())
  nome      String
  cognome   String
  email     String   @unique
  password  String
  ruolo     Ruolo    @default(DIPENDENTE)
  createdAt DateTime @default(now())

  richiesteComeDipendente RichiestaRimborso[] @relation("DipendenteRichieste")
  richiesteValutate       RichiestaRimborso[] @relation("ResponsabileValutazioni")
}

model CategoriaSpesa {
  id          Int                 @id @default(autoincrement())
  descrizione String              @unique
  richieste   RichiestaRimborso[]
}

model RichiestaRimborso {
  id                      Int            @id @default(autoincrement())
  dataInserimento         DateTime       @default(now())
  dataSpesa               DateTime
  importo                 Decimal        @db.Decimal(10, 2)
  descrizione             String
  riferimentoGiustificativo String?
  stato                   StatoRichiesta @default(IN_ATTESA)

  dipendenteId Int
  dipendente   Utente @relation("DipendenteRichieste", fields: [dipendenteId], references: [id])

  categoriaId Int
  categoria   CategoriaSpesa @relation(fields: [categoriaId], references: [id])

  dataValutazione           DateTime?
  responsabileValutazioneId Int?
  responsabileValutazione   Utente?   @relation("ResponsabileValutazioni", fields: [responsabileValutazioneId], references: [id])
  motivazioneRifiuto        String?
  dataLiquidazione          DateTime?
}
